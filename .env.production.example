APP_ENV=production
APP_HOST=0.0.0.0

# Render provides PORT automatically. Do not set APP_PORT on Render unless you need a local override.

# Supabase on Render: prefer Session Pooler / Transaction Pooler, not Direct connection.
# Direct hosts like db.<project>.supabase.co can be IPv6-only and fail on Render.
# Supabase pooler usually uses port 6543.
# Encode special password characters. For example: ! -> %21, ? -> %3F, @ -> %40
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_SSL=true

# Example: https://family-finance-bot.onrender.com
PUBLIC_BASE_URL=
# Set false on Render when Telegram polling runs on another server, for example iMac.
BOT_ENABLED=false

TELEGRAM_BOT_TOKEN=
ALLOWED_TELEGRAM_USER_IDS=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

API_SECRET_KEY=
DEFAULT_CURRENCY=EUR
DEFAULT_TIMEZONE=Europe/Madrid

MAX_RECEIPT_SIZE_MB=10
LOG_LEVEL=INFO
